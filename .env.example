OPS_APP_NAME=Personal Ops Hub
PORT=8080
OPS_DB_PATH=/data/ops-hub.db
OPS_COLLECTION_INTERVAL_SECONDS=30
OPS_RETENTION_HOURS=24

# Dashboard basic auth. Leave empty for local development only.
OPS_ADMIN_USER=admin
OPS_ADMIN_PASSWORD=

# Token for mutating endpoints such as manual checks, backup reports, and alert tests.
OPS_ADMIN_TOKEN=

# Alert targets. Configure one or both.
OPS_DISCORD_WEBHOOK_URL=
OPS_TELEGRAM_BOT_TOKEN=
OPS_TELEGRAM_CHAT_ID=

# Resource thresholds.
OPS_DISK_CRITICAL_PERCENT=80
OPS_MEMORY_CRITICAL_PERCENT=90
OPS_CPU_CRITICAL_PERCENT=95
OPS_DISK_PATHS=/

# Checks.
OPS_HTTP_CHECKS=ops-hub=http://127.0.0.1:8080/api/health
OPS_TCP_CHECKS=
OPS_DOCKER_CONTAINERS=
OPS_BACKUP_MARKERS=

# Automation.
OPS_TIME_ZONE=Asia/Seoul
OPS_DAILY_REPORT_HOUR=9
OPS_DAILY_REPORT_MINUTE=0
OPS_GITHUB_WEBHOOK_SECRET=
OPS_DEPLOY_COMMAND=
OPS_DEPLOY_WORKDIR=
OPS_RSS_FEEDS=
OPS_PAGE_WATCHES=
